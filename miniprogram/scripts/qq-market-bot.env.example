TWELVE_DATA_API_KEY=your_twelve_data_api_key
MARKET_BOT_TIMEZONE=Asia/Shanghai
# 合并后的科技/AI 新闻条数，默认会回退为 MARKET_TECH_NEWS_LIMIT + MARKET_AI_NEWS_LIMIT
MARKET_TECH_AI_NEWS_LIMIT=10
MARKET_TECH_NEWS_LIMIT=5
MARKET_AI_NEWS_LIMIT=5
MARKET_FOLLOW_BUILDER_NEWS_LIMIT=5
MARKET_FINANCE_NEWS_LIMIT=10
MARKET_NEWS_SUMMARY_MAX_LENGTH=48
MARKET_MESSAGE_MAX_LENGTH=1600
MARKET_AI_LLM_ENABLED=1
MARKET_AI_LLM_PROVIDER=deepseek
MARKET_AI_LLM_FALLBACK_PROVIDER=deepseek
MARKET_AI_LLM_TIMEOUT_MS=45000
DEEPSEEK_MODEL=deepseek-chat
DEEPSEEK_API_KEY=
# 如需手动切回 Gemini，再取消下面两行注释并把 provider 改成 gemini
# GEMINI_MODEL=gemini-2.5-flash
# GEMINI_API_KEY=
EASTMONEY_APIKEY=
EASTMONEY_SKILL_QUERY=最新财经快讯

# 发送模式：onebot 或 qq-official
QQ_BOT_MODE=onebot

# OneBot v11 示例（NapCat / go-cqhttp 常见）
# HTTP / WS 二选一即可；同时填写时默认优先走 HTTP
ONEBOT_HTTP_URL=http://127.0.0.1:3000
# ONEBOT_WS_URL=ws://127.0.0.1:3001
ONEBOT_MESSAGE_TYPE=group
ONEBOT_TARGET_ID=123456789
# 额外目标可选，格式：group:群号,private:QQ号
# ONEBOT_EXTRA_TARGETS=private:12345678,group:987654321
ONEBOT_ACCESS_TOKEN=

# QQ 官方机器人示例（仅在你明确需要时启用）
# QQ_BOT_MODE=qq-official
# QQ_BOT_APP_ID=your_app_id
# QQ_BOT_CLIENT_SECRET=your_client_secret
# QQ_BOT_TARGET_TYPE=group
# QQ_BOT_TARGET_ID=your_group_openid
# QQ_BOT_API_BASE_URL=https://api.sgroup.qq.com
