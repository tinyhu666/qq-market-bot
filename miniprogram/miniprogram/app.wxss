page {
  background: linear-gradient(180deg, #f5f7fb 0%, #eef3ff 100%);
  color: #172033;
  font-size: 28rpx;
  min-height: 100%;
}

view,
text {
  box-sizing: border-box;
}

button {
  box-sizing: border-box;
}

.action-button {
  display: flex;
  align-items: center;
  justify-content: center;
  width: 100%;
  min-height: 88rpx;
  padding: 0 24rpx;
  border-radius: 20rpx;
  font-size: 28rpx;
  font-weight: 600;
}

.action-button::after {
  border: none;
}

.action-button--primary {
  background: linear-gradient(135deg, #1f5eff 0%, #73a1ff 100%);
  color: #ffffff;
  box-shadow: 0 18rpx 32rpx rgba(31, 94, 255, 0.24);
}

.action-button--secondary {
  background: #edf3ff;
  color: #2252c7;
}
