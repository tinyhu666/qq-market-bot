.card {
  display: flex;
  flex-direction: column;
  gap: 24rpx;
  padding: 28rpx;
  border: 1rpx solid rgba(31, 61, 122, 0.08);
  border-radius: 24rpx;
  background: rgba(255, 255, 255, 0.92);
  box-shadow: 0 18rpx 40rpx rgba(26, 49, 102, 0.08);
}

.card-header {
  display: flex;
  align-items: flex-start;
  justify-content: space-between;
  gap: 16rpx;
}

.card-copy {
  display: flex;
  flex: 1;
  flex-direction: column;
  gap: 8rpx;
}

.card-title {
  color: #172033;
  font-size: 30rpx;
  font-weight: 600;
}

.card-description {
  color: #667085;
  font-size: 24rpx;
  line-height: 1.6;
}

.card-badge {
  padding: 10rpx 18rpx;
  border-radius: 999rpx;
  background: #edf3ff;
  color: #2252c7;
  font-size: 22rpx;
  font-weight: 600;
  white-space: nowrap;
}

.card-body {
  display: flex;
  flex-direction: column;
  gap: 20rpx;
}
